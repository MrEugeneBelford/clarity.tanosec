+
+/* Cybersecurity-themed loading screen animations */
+@keyframes shield-fill {
+  0% {
+    transform: translateY(105px);
+    opacity: 0.3;
+  }
+  50% {
+    opacity: 0.8;
+  }
+  100% {
+    transform: translateY(-105px);
+    opacity: 0.3;
+  }
+}
+
+@keyframes scan {
+  0% {
+    transform: translateY(-4px);
+    opacity: 0;
+  }
+  10% {
+    opacity: 1;
+  }
+  90% {
+    opacity: 1;
+  }
+  100% {
+    transform: translateY(120px);
+    opacity: 0;
+  }
+}
+
+@keyframes data-stream-1 {
+  0%, 100% {
+    opacity: 0.2;
+    transform: translateY(0);
+  }
+  50% {
+    opacity: 0.8;
+    transform: translateY(10px);
+  }
+}
+
+@keyframes data-stream-2 {
+  0%, 100% {
+    opacity: 0.2;
+    transform: translateY(0);
+  }
+  50% {
+    opacity: 0.8;
+    transform: translateY(-8px);
+  }
+}
+
+@keyframes data-stream-3 {
+  0%, 100% {
+    opacity: 0.2;
+    transform: translateY(0);
+  }
+  50% {
+    opacity: 0.8;
+    transform: translateY(12px);
+  }
+}
+
+.animate-shield-fill {
+  animation: shield-fill 2.2s ease-in-out infinite;
+}
+
+.animate-scan {
+  animation: scan 1.1s ease-in-out infinite;
+}
+
+.animate-data-stream-1 {
+  animation: data-stream-1 1.5s ease-in-out infinite;
+}
+
+.animate-data-stream-2 {
+  animation: data-stream-2 1.8s ease-in-out infinite 0.3s;
+}
+
+.animate-data-stream-3 {
+  animation: data-stream-3 1.3s ease-in-out infinite 0.6s;
+}
